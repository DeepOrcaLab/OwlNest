# Optional overrides for the extension's runtime URLs/domains.
# By default the extension uses localhost values (safe fallback for open-source builds).
# For production, set these to your OwlNest deployment URLs.
# Values must already be canonical:
# - URLs must not end with a trailing slash
# - origins/domains are comma-separated with no spaces
#
# WXT_API_URL=https://api.owlnest.app
# WXT_WEBSITE_URL=https://www.owlnest.app
# WXT_OFFICIAL_SITE_ORIGINS=https://owlnest.app,https://www.owlnest.app
# WXT_AUTH_COOKIE_DOMAINS=owlnest.app
#
# Required in production:
# WXT_GOOGLE_CLIENT_ID=your-google-client-id
# WXT_POSTHOG_HOST=https://us.i.posthog.com
# WXT_POSTHOG_API_KEY=phc_your_posthog_key
